# Node/Express Backend Environment

# PostgreSQL (DigitalOcean Managed Database)
DATABASE_URL=postgresql://user:password@host:25060/health_link?sslmode=require
# Set to true for hosted PostgreSQL connections such as DigitalOcean Managed Database.
DATABASE_SSL=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Default seeded users
ADMIN_EMAIL=admin@healthlink.ug
ADMIN_NAME=Admin User
ADMIN_PASSWORD=HealthLinkAdmin123!
STAFF_EMAIL=staff@healthlink.ug
STAFF_NAME=Staff User
STAFF_PASSWORD=HealthLinkStaff123!

# SMTP (required for real patient OTP email delivery)
# Preferred OTP transport (Resend)
RESEND_API_KEY=
RESEND_FROM=no-reply@your-domain.com

# Fallback OTP transport (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="Health Link <no-reply@healthlink.ug>"

# Server
PORT=8000
FRONTEND_URL=http://127.0.0.1:5173
# Optional: comma-separated list of additional allowed frontend origins.
# Example: FRONTEND_URLS=https://healthlink.app,https://www.healthlink.app
FRONTEND_URLS=
SEED_ON_START=true
