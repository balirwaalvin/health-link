# Node/Express Backend Environment

# Appwrite (required)
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATA_BUCKET_ID=
APPWRITE_STORE_FILE_ID=health-link-store
APPWRITE_STORE_FILE_NAME=health-link-store.json

# Default seeded Appwrite users
ADMIN_EMAIL=admin@healthlink.ug
ADMIN_NAME=Admin User
ADMIN_PASSWORD=HealthLinkAdmin123!
STAFF_EMAIL=staff@healthlink.ug
STAFF_NAME=Staff User
STAFF_PASSWORD=HealthLinkStaff123!

# SMTP (required for real patient OTP email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="Health Link <no-reply@healthlink.ug>"

# Server
PORT=8000
FRONTEND_URL=http://127.0.0.1:5173
# Optional: comma-separated list of additional allowed frontend origins.
# Example: FRONTEND_URLS=https://myapp.appwrite.network,https://healthlink.app
FRONTEND_URLS=
SEED_ON_START=true
