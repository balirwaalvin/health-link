# Node/Express Backend Environment

# PostgreSQL (DigitalOcean)
DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require

# Clerk
CLERK_SECRET_KEY=sk_test_...
ADMIN_EMAIL=admin@healthlink.ug
ADMIN_NAME=Admin User
ADMIN_PASSWORD=HealthLinkAdmin123!
STAFF_EMAIL=staff@healthlink.ug
STAFF_NAME=Staff User
STAFF_PASSWORD=HealthLinkStaff123!
APP_AUTH_SECRET=change-me

# SMTP (required for real patient OTP email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM="Health Link <no-reply@healthlink.ug>"

# Server
PORT=8000
FRONTEND_URL=http://127.0.0.1:5173
SEED_ON_START=true
